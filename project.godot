ResourceLoading="*uid://ck030kondt37s"

[display]

window/size/viewport_width=1080
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/scale=1.3
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/fictional_options_manager/plugin.cfg", "res://addons/fictional_resource_loader/plugin.cfg", "res://addons/trail_2d/plugin.cfg")

[global_group]

